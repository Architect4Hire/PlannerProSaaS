{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "blobs": "UseDevelopmentStorage=true"
  },
  "Tenancy": {
    "TenantCacheTtl": "00:00:30",
    "MembershipCacheTtl": "00:00:30"
  },
  "ReverseProxy": {
    "Routes": {
      "access-public": {
        "ClusterId": "access",
        "Match": { "Path": "/api/public/{**catch-all}" }
      },
      "access-auth": {
        "ClusterId": "access",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "access-signup": {
        "ClusterId": "access",
        "Match": { "Path": "/api/signup" }
      },
      "access-invitations": {
        "ClusterId": "access",
        "Match": { "Path": "/api/invitations/{**catch-all}" }
      },
      "access-me-tenants": {
        "ClusterId": "access",
        "AuthorizationPolicy": "RequireAuthenticatedCaller",
        "Match": { "Path": "/api/me/tenants" }
      },
      "access-admin": {
        "ClusterId": "access",
        "AuthorizationPolicy": "RequirePlatformAdmin",
        "Match": { "Path": "/api/admin/{**catch-all}" }
      },
      "access-tenant-scoped": {
        "ClusterId": "access",
        "AuthorizationPolicy": "RequireAuthenticatedCaller",
        "Match": { "Path": "/api/t/{**catch-all}" }
      }
    },
    "Clusters": {
      "access": {
        "Destinations": {
          "destination1": { "Address": "http://access" }
        }
      }
    }
  }
}
